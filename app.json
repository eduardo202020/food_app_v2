{
  "expo": {
    "name": "cheff_app",
    "slug": "cheff_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "cheff",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-home-dark.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/images/splash-home-dark.png",
        "resizeMode": "cover",
        "backgroundColor": "#0B1220"
      }
    },
    "android": {
      "splash": {
        "image": "./assets/images/splash-home-dark.png",
        "resizeMode": "cover",
        "backgroundColor": "#0B1220"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FACC15"
      },
      "package": "com.jguevaral.cheff_app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableBundleCompression": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "48850b30-a444-4c65-93d1-1a7b4387fd8c"
      }
    }
  }
}
